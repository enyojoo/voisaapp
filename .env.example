# Supabase (Expo loads EXPO_PUBLIC_* at build time). Use Project API keys → Publishable key.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# Optional: pin Edge Functions region (e.g. eu-west-1, us-east-1) if invoke relay/network routing is flaky.
# EXPO_PUBLIC_SUPABASE_FUNCTIONS_REGION=eu-west-1

# Gemini Live Translate — ephemeral tokens minted by Edge Function `gemini-live-token`.
# Set as Supabase secret (Dashboard → Project Settings → Edge Functions → Secrets):
#   GEMINI_API_KEY=...
# Deploy: `supabase functions deploy gemini-live-token`
#
# After changing Edge secrets, redeploy the function.

# Dev-only: verbose Gemini client logs in Metro (`EXPO_PUBLIC_VOISA_VERBOSE_GEMINI=1`).
# EXPO_PUBLIC_VOISA_VERBOSE_GEMINI=1

# Translated audio playback gain (0.25–1.5). Try 0.92 if output clips on the phone speaker.
# EXPO_PUBLIC_VOISA_TRANSLATED_AUDIO_VOLUME=1
