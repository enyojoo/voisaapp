{
  "expo": {
    "name": "Voisa",
    "slug": "voisa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/ios-light.png",
    "scheme": "voisa",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.easner.voisa",
      "icon": {
        "light": "./assets/icons/ios-light.png",
        "dark": "./assets/icons/ios-dark.png",
        "tinted": "./assets/icons/ios-tinted.png"
      },
      "infoPlist": {
        "CFBundleDisplayName": "Voisa",
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "Voisa uses the microphone for live speech translation."
      }
    },
    "android": {
      "package": "com.easner.voisa",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/adaptive-icon.png",
        "backgroundColor": "#93A000"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icons/ios-light.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-secure-store",
      "expo-audio",
      [
        "react-native-audio-api",
        {
          "iosBackgroundMode": false,
          "androidForegroundService": false,
          "androidPermissions": []
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/icons/splash-icon-light.png",
          "backgroundColor": "#93A000",
          "dark": {
            "image": "./assets/icons/splash-icon-dark.png",
            "backgroundColor": "#93A000"
          },
          "imageWidth": 200
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "42fa3e66-1f20-4ddd-9445-475078dae43a"
      }
    },
    "owner": "easner"
  }
}
